# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Production: use Neon pooled URL for the app, direct URL for Prisma CLI.
# Get both from https://console.neon.tech → your project → Connect
#
# Pooled (app runtime — serverless / Next.js):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
#
# Direct (migrations, db push, seed):
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"
#
# Local dev (optional — Docker Compose):
# DATABASE_URL="postgresql://serverclips:serverclips@localhost:5432/serverclips?schema=public"
# DIRECT_URL="postgresql://serverclips:serverclips@localhost:5432/serverclips?schema=public"

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth.js ────────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── UploadThing (recommended for Vercel — client uploads, no S3 setup) ───
# Free at https://uploadthing.com/dashboard → create app → copy API key
UPLOADTHING_TOKEN=""

# ─── Object storage (optional alternative — S3-compatible API) ──────────────
# AWS S3, Cloudflare R2, Backblaze B2, etc.
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# R2 / custom endpoint (leave empty for AWS S3):
S3_ENDPOINT=""
S3_PUBLIC_URL=""
S3_FORCE_PATH_STYLE="false"

# ─── Public app URL (SEO / sitemap) ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
